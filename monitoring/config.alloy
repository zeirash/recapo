prometheus.scrape "arion" {
  targets = [{"__address__" = sys.env("ARION_URL")}]
  forward_to = [prometheus.remote_write.grafana_cloud.receiver]
  scrape_interval = "15s"
  metrics_path = "/metrics"
  scheme = "https"
}

prometheus.remote_write "grafana_cloud" {
  endpoint {
    url = sys.env("GRAFANA_REMOTE_WRITE_URL")
    basic_auth {
      username = sys.env("GRAFANA_USER_ID")
      password = sys.env("GRAFANA_API_KEY")
    }
  }
}
