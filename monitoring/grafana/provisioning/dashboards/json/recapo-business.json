{
  "title": "Recapo Business",
  "uid": "recapo-business",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "1h",
  "panels": [
    {
      "id": 1,
      "title": "Total Shops",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "targets": [
        {
          "rawQuery": true,
          "rawSql": "SELECT COUNT(*) AS value FROM shops",
          "format": "table"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none"
      }
    },
    {
      "id": 2,
      "title": "Shops with Subscription",
      "type": "stat",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "targets": [
        {
          "rawQuery": true,
          "rawSql": "SELECT COUNT(DISTINCT shop_id) AS value FROM subscriptions",
          "format": "table"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none"
      }
    },
    {
      "id": 3,
      "title": "Subscriptions by Status",
      "type": "piechart",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "targets": [
        {
          "rawQuery": true,
          "rawSql": "SELECT status AS metric, COUNT(DISTINCT shop_id) AS value FROM subscriptions GROUP BY status",
          "format": "table"
        }
      ],
      "options": {
        "displayLabels": ["value"],
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "transformations": [
        {
          "id": "rowsToFields",
          "options": {}
        }
      ]
    },
    {
      "id": 4,
      "title": "Request Rate (rps)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total[1m]))",
          "legendFormat": "rps"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      }
    },
    {
      "id": 5,
      "title": "P95 Latency (ms)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[1m])) by (le)) * 1000",
          "legendFormat": "p95"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ms" }
      }
    },
    {
      "id": 6,
      "title": "Error Rate %",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{status_code=~\"5..\"}[1m])) / sum(rate(http_requests_total[1m])) * 100",
          "legendFormat": "error %"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percent", "min": 0, "max": 100 }
      }
    },
    {
      "id": 7,
      "title": "Success Rate %",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{status_code=~\"2..\"}[1m])) / sum(rate(http_requests_total[1m])) * 100",
          "legendFormat": "success %"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percent", "min": 0, "max": 100 }
      }
    },
    {
      "id": 8,
      "title": "DB Open Connections",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 28, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "recapo_sql_open_connections",
          "legendFormat": "open connections"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    }
  ],
  "templating": {
    "list": [
      {
        "name": "DS_POSTGRESQL",
        "type": "datasource",
        "query": "postgres",
        "hide": 2,
        "refresh": 1,
        "current": {}
      },
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "hide": 2,
        "refresh": 1,
        "current": {}
      }
    ]
  }
}
